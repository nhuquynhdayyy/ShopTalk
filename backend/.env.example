# Connection string của PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shoptalk
PORT=3000

# 1. API Key của LLM (Dùng Groq hoặc OpenAI)
GROQ_API_KEY=YOUR_GROQ_API_KEY
LLM_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# 2. Cấu hình ứng dụng Agora
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# 3. Credentials RESTful API của Agora
AGORA_CUSTOMER_ID=YOUR_AGORA_CUSTOMER_ID
AGORA_CUSTOMER_SECRET=YOUR_AGORA_CUSTOMER_SECRET
AGORA_AGENT_ID=YOUR_AGORA_AGENT_ID

# 4. URL công khai của backend (cần ngrok khi dev local)
BACKEND_PUBLIC_URL=https://YOUR_SUBDOMAIN.ngrok-free.dev
NGROK_URL=https://YOUR_SUBDOMAIN.ngrok-free.dev

# 5. Cấu hình Azure TTS
AZURE_TTS_KEY=YOUR_AZURE_TTS_KEY
AZURE_TTS_REGION=southeastasia

# 6. Ví Blockchain của người bán (Solana Wallet Address)
SELLER_WALLET=5hrFH2N3hCRaGNMUbALRhT7R3qWWe9uHMkCFhFa1JReJ

# 7. Escalation rules
ESCALATION_ORDER_THRESHOLD_USDC=100
ESCALATION_REPEAT_QUESTION_LIMIT=2
